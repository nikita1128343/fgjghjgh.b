#include <iostream>
#include <iomanip>
#include <vector>

using namespace std;

int main() {
    setlocale(LC_ALL, "RUS");
    int n;
    cout << "Введите размер матрицы n: ";
    cin >> n;

    vector<vector<double>> A(n, vector<double>(n));
    vector<vector<double>> L(n, vector<double>(n, 0.0));
    vector<vector<double>> U(n, vector<double>(n, 0.0));
    vector<vector<double>> invA(n, vector<double>(n, 0.0));

    cout << "Введите матрицу A построчно:" << endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> A[i][j];
        }
    }

    // LU-разложение (L с единичной диагональю)
    for (int i = 0; i < n; i++) {
        // Вычисляем U
        for (int k = i; k < n; k++) {
            double sum = 0.0;
            for (int j = 0; j < i; j++) {
                sum += L[i][j] * U[j][k]; //сумма произв элементов нижн на верх для j
            }
            U[i][k] = A[i][k] - sum; //то что осталось записываем в U[i][k]
        }

        // Вычисляем L
        for (int k = i; k < n; k++) {
            if (i == k) {
                L[i][i] = 1.0; //ставлю 1(метод Дулиттла)
            }
            else {
                double sum = 0.0;
                for (int j = 0; j < i; j++) {
                    sum += L[k][j] * U[j][i];//формула умножения матриц
                }
                L[k][i] = (A[k][i] - sum) / U[i][i];//вычли накопленное и поделили на диагональный эл-т(A=L*U)
            }
        }
    }

    // Поиск обратной матрицы: решаем A * X = I
    for (int col = 0; col < n; col++) {//находим обратную матрицу(каждый столбец отдельно)(L*Y = столбец единичной матрицы)
        // 1. Решаем L * Y = I(:, col)
        vector<double> Y(n, 0.0);
        for (int i = 0; i < n; i++) {
            double sum = 0.0;
            for (int j = 0; j < i; j++) {
                sum += L[i][j] * Y[j];//берем строку i из L умн её эл-ты на знач Y
            }
            Y[i] = ((i == col ? 1.0 : 0.0) - sum);//если i == col - диагональный эл-т(1), иначе 0
        }

        // 2. Решаем U * X = Y(нужно найти X-столбец обрат матр)
        for (int i = n - 1; i >= 0; i--) {
            double sum = 0.0;
            for (int j = i + 1; j < n; j++) {
                sum += U[i][j] * invA[j][col];
            }
            invA[i][col] = (Y[i] - sum) / U[i][i];
        }
    }

    // Вывод результата
    cout << fixed << setprecision(10);
    cout << "\nОбратная матрица:" << endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << setw(12) << invA[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}

