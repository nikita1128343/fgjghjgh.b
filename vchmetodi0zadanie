#include <iostream>
#include <vector>
#include <cmath>

using namespace std;

int main() {
    setlocale(LC_ALL, "rus");
    int n;
    cout << "Введите размерность системы (n): ";
    cin >> n;

    // Расширенная матрица n x (n+1)
    vector<vector<double>> a(n, vector<double>(n + 1));

    cout << "Введите коэффициенты системы (матрица A и столбец b):\n";
    cout << "Каждую строку вводите как n коэффициентов и затем b\n";

    for (int i = 0; i < n; i++) {
        for (int j = 0; j <= n; j++) {
            cin >> a[i][j];
        }
    }

    // Метод Гаусса
    for (int i = 0; i < n; i++) {
        // Поиск максимального элемента в столбце (частичный выбор главного элемента)
        int maxRow = i;
        for (int k = i + 1; k < n; k++) {
            if (fabs(a[k][i]) > fabs(a[maxRow][i])) {
                maxRow = k;
            }
        }

        // Меняем строки местами
        swap(a[i], a[maxRow]);

        // Проверка на вырожденность
        if (fabs(a[i][i]) < 1e-9) {
            cout << "Система не имеет единственного решения.\n";
            return 0;
        }

        // Приведение к треугольному виду
        for (int k = i + 1; k < n; k++) {
            double factor = a[k][i] / a[i][i];
            for (int j = i; j <= n; j++) {
                a[k][j] -= factor * a[i][j];
            }
        }
    }

    // Обратный ход
    vector<double> x(n);
    for (int i = n - 1; i >= 0; i--) {
        x[i] = a[i][n];
        for (int j = i + 1; j < n; j++) {
            x[i] -= a[i][j] * x[j];
        }
        x[i] /= a[i][i];
    }

    // Вывод результата
    cout << "\nРешение системы:\n";
    for (int i = 0; i < n; i++) {
        cout << "x" << i + 1 << " = " << x[i] << endl;
    }

    return 0;
}
