#include <iostream>
#include <cmath>
#include <iomanip>
using namespace std;

// ============================================================================
// ТЕОРИЯ: Методы параболической интерполяции (задание №5)
// ============================================================================
// Суть: для решения уравнения f(x)=0 строим квадратичную параболу по трём точкам
// и находим её корень. Повторяем, пока не достигнем точности.
//
// Прямой метод (Мюллер): парабола p(x) = a(x-x₂)² + b(x-x₂) + c
// Обратный метод: строим x = g(y) и подставляем y=0
//
// Сравнение погрешностей: |x_найденный - x_точный|
// ============================================================================

// Глобальные коэффициенты многочлена: a3·x³ + a2·x² + a1·x + a0
double a3, a2, a1, a0;

// Функция f(x) - вычисляет значение многочлена в точке x
// Теория: ищем x*, такое что f(x*)=0
double f(double x) {
    return a3*x*x*x + a2*x*x + a1*x + a0;
}

// ========================= ПРЯМОЙ МЕТОД (МЮЛЛЕРА) =========================
// Теория:
// 1. Берём три точки (x₀,f₀), (x₁,f₁), (x₂,f₂)
// 2. Строим параболу p(x) = a(x-x₂)² + b(x-x₂) + c
//    Коэффициенты через разделённые разности:
//    c = f₂
//    b = a·h₂ + d₂, где d₂ = (f₂-f₁)/(x₂-x₁)
//    a = (d₂-d₁)/(h₁+h₂), где d₁ = (f₁-f₀)/(x₁-x₀)
// 3. Решаем a·t² + b·t + c = 0, t = x-x₂
// 4. t = -2c/(b ± √(b²-4ac)) — выбираем корень, ближайший к x₂
// 5. x₃ = x₂ + t — новое приближение
// 6. Повторяем с (x₁, x₂, x₃)
// Сходимость: порядок ~1.84 (сверхлинейная)
double muller(double x0, double x1, double x2, double eps, int& iter) {
    iter = 0;  // обнуляем счётчик итераций
    
    for (int i = 0; i < 100; i++) {  // максимум 100 итераций
        // Значения функции в трёх точках
        double f0 = f(x0), f1 = f(x1), f2 = f(x2);
        
        // Шаги между точками: h₁ = x₁-x₀, h₂ = x₂-x₁
        double h1 = x1 - x0;
        double h2 = x2 - x1;
        
        // Защита от деления на ноль
        if (fabs(h1) < 1e-12 || fabs(h2) < 1e-12) return NAN;
        
        // Первые разделённые разности: d₁ = (f₁-f₀)/(x₁-x₀), d₂ = (f₂-f₁)/(x₂-x₁)
        double d1 = (f1 - f0) / h1;
        double d2 = (f2 - f1) / h2;
        
        // Вторая разделённая разность → коэффициент a при t²
        double a = (d2 - d1) / (h2 + h1);
        // Коэффициент b при t
        double b = a * h2 + d2;
        // Свободный член c = f₂
        double c = f2;
        
        // Дискриминант квадратного уравнения a·t² + b·t + c = 0
        double D = b*b - 4*a*c;
        if (D < 0) return NAN;  // комплексные корни — метод не работает
        
        double sqrtD = sqrt(D);
        
        // Выбираем знаменатель с бóльшим модулем для устойчивости
        // Формула: t = -2c/(b ± √D)
        double denom = (fabs(b - sqrtD) > fabs(b + sqrtD)) ? (b - sqrtD) : (b + sqrtD);
        if (fabs(denom) < 1e-12) return NAN;  // защита от деления на ноль
        
        double t = -2*c / denom;   // приращение t = x - x₂
        double x_new = x2 + t;      // новое приближение корня
        iter++;                     // увеличиваем счётчик
        
        // Критерий останова: изменение меньше eps или значение функции близко к нулю
        if (fabs(t) < eps || fabs(f(x_new)) < eps) {
            return x_new;
        }
        
        // Сдвиг точек: отбрасываем x₀, сдвигаем x₁→x₀, x₂→x₁, x_new→x₂
        x0 = x1;
        x1 = x2;
        x2 = x_new;
    }
    return x2;  // возвращаем последнее приближение
}

// ======================= ОБРАТНЫЙ МЕТОД =======================
// Теория:
// 1. Берём три точки (x₀,y₀), (x₁,y₁), (x₂,y₂), где yᵢ = f(xᵢ)
// 2. Строим параболу x = g(y) = a·y² + b·y + c
//    Коэффициенты через разделённые разности по y
// 3. Корню f(x)=0 соответствует y=0 → x* ≈ g(0) = c
// 4. Повторяем, обновляя точки
//
// Применяется, когда f(x) немонотонна или плохо приближается полиномом по x
double inverse_parabolic(double x0, double x1, double x2, double eps, int& iter) {
    iter = 0;
    // Вычисляем yᵢ = f(xᵢ) в трёх точках
    double y0 = f(x0), y1 = f(x1), y2 = f(x2);
    
    for (int i = 0; i < 100; i++) {
        // Разности по y: h₁ = y₁-y₀, h₂ = y₂-y₁
        double h1 = y1 - y0;
        double h2 = y2 - y1;
        if (fabs(h1) < 1e-12 || fabs(h2) < 1e-12) return NAN;
        
        // Первые разделённые разности для x(y)
        double d1 = (x1 - x0) / h1;
        double d2 = (x2 - x1) / h2;
        
        // Вторая разделённая разность — коэффициент при y²
        double a = (d2 - d1) / (h2 + h1);
        // Коэффициент при y
        double b = a * h2 + d2;
        // Свободный член c = x₂ (при y=y₂)
        double c = x2;
        
        // Подставляем y=0 в x = a·y² + b·y + c → получаем x_new = c
        double x_new = c;
        double f_new = f(x_new);
        iter++;
        
        // Критерий останова: значение функции близко к нулю
        if (fabs(f_new) < eps) return x_new;
        
        // Обновляем точки: заменяем ту, у которой |y| максимальный
        // (чем дальше от нуля, тем меньше вклад в интерполяцию)
        if (fabs(y0) > fabs(y1) && fabs(y0) > fabs(y2)) {
            x0 = x_new; y0 = f_new;
        } else if (fabs(y1) > fabs(y2)) {
            x1 = x_new; y1 = f_new;
        } else {
            x2 = x_new; y2 = f_new;
        }
    }
    return NAN;
}

// ========================= ОСНОВНАЯ ПРОГРАММА =========================
int main() {
    setlocale(LC_ALL, "Russian");
    
    cout << "========================================\n";
    cout << "Метод параболической интерполяции\n";
    cout << "Решение уравнения вида: a3*x^3 + a2*x^2 + a1*x + a0 = 0\n";
    cout << "========================================\n\n";
    
    // Ввод коэффициентов с клавиатуры
    cout << "Введите коэффициенты:\n";
    cout << "a3 = "; cin >> a3;
    cout << "a2 = "; cin >> a2;
    cout << "a1 = "; cin >> a1;
    cout << "a0 = "; cin >> a0;
    
    // Вывод уравнения на экран
    cout << "\nУравнение: ";
    if (a3 != 0) cout << a3 << "x^3 ";
    if (a2 > 0 && a3 != 0) cout << "+ " << a2 << "x^2 ";
    else if (a2 != 0) cout << a2 << "x^2 ";
    if (a1 > 0 && (a3 != 0 || a2 != 0)) cout << "+ " << a1 << "x ";
    else if (a1 != 0) cout << a1 << "x ";
    if (a0 > 0 && (a3 != 0 || a2 != 0 || a1 != 0)) cout << "+ " << a0;
    else if (a0 != 0) cout << a0;
    if (a3 == 0 && a2 == 0 && a1 == 0 && a0 == 0) cout << "0";
    cout << " = 0\n";
    
    // Ввод точного корня (для сравнения погрешностей по заданию №5)
    double exact_root;
    cout << "\nВведите точное значение корня: ";
    cin >> exact_root;
    
    // Ввод отрезка изоляции корня [a,b]
    double a, b;
    cout << "Введите отрезок [a b]: ";
    cin >> a >> b;
    
    // Теорема Больцано-Коши: если f(a)·f(b) < 0, то на отрезке есть корень
    if (f(a) * f(b) >= 0) {
        cout << "Ошибка: на отрезке нет корня!\n";
        return 1;
    }
    
    // Ввод точности вычислений
    double eps;
    cout << "Введите точность (например 0.000001): ";
    cin >> eps;
    
    // Начальные точки: левый конец (x₀), правый конец (x₁), середина (x₂)
    double x0 = a, x1 = b, x2 = (a+b)/2;
    
    // ----- Прямой метод (Мюллер) -----
    int iter1;
    double root1 = muller(x0, x1, x2, eps, iter1);
    
    // ----- Обратный метод -----
    int iter2;
    double root2 = inverse_parabolic(x0, x1, x2, eps, iter2);
    
    // ----- Вывод результатов -----
    cout << fixed << setprecision(10);
    cout << "\n========================================\n";
    cout << "РЕЗУЛЬТАТЫ:\n";
    cout << "========================================\n";
    
    if (!isnan(root1)) {
        cout << "Прямая интерполяция:    x = " << root1 << "\n";
        cout << "Погрешность:            " << fabs(root1 - exact_root) << "\n";
        cout << "Итераций:               " << iter1 << "\n\n";
    } else {
        cout << "Прямая интерполяция:    НЕ СОШЛАСЬ\n\n";
    }
    
    if (!isnan(root2)) {
        cout << "Обратная интерполяция:  x = " << root2 << "\n";
        cout << "Погрешность:            " << fabs(root2 - exact_root) << "\n";
        cout << "Итераций:               " << iter2 << "\n\n";
    } else {
        cout << "Обратная интерполяция:  НЕ СОШЛАСЬ\n\n";
    }
    
    // Сравнение погрешностей (обязательно по заданию №5)
    if (!isnan(root1) && !isnan(root2)) {
        double err1 = fabs(root1 - exact_root);
        double err2 = fabs(root2 - exact_root);
        cout << "========================================\n";
        cout << "СРАВНЕНИЕ ПОГРЕШНОСТЕЙ:\n";
        cout << "Прямая:   " << err1 << "\n";
        cout << "Обратная: " << err2 << "\n";
        if (err1 < err2) cout << "Вывод: прямая интерполяция ТОЧНЕЕ\n";
        else if (err2 < err1) cout << "Вывод: обратная интерполяция ТОЧНЕЕ\n";
        else cout << "Вывод: погрешности равны\n";
    }
    
    return 0;
}
