#include <iostream>
#include <fstream>
#include <vector>
#include <iomanip>
#include <cmath>

using namespace std;

// Построение таблицы обратных разностей
vector<vector<double>> build_table(const vector<double>& y) {
    int n = y.size();
    vector<vector<double>> tab(n, vector<double>(n, 0.0));

    for (int i = 0; i < n; ++i) {
        tab[0][i] = y[i];
    }

    for (int k = 1; k < n; ++k) {
        for (int i = k; i < n; ++i) {
            tab[k][i] = tab[k-1][i] - tab[k-1][i-1];
        }
    }
    return tab;
}

// Интерполяция назад по Ньютону
double newton_back(double x, const vector<double>& xx, const vector<double>& yy,
                   const vector<vector<double>>& tab) {
    int n = xx.size();
    double h = xx[1] - xx[0];
    double t = (x - xx[n-1]) / h;

    double res = tab[0][n-1];
    double pr = 1.0;

    for (int k = 1; k < n; ++k) {
        pr *= (t + k - 1) / k;
        res += tab[k][n-1] * pr;
    }
    return res;
}

int main() {
    setlocale(LC_ALL, "Russian");

    // ---- Ввод данных ------------------------------------------
    int n;
    cout << "Введите число точек: ";
    cin >> n;

    if (n < 2) {
        cerr << "Ошибка: нужно минимум 2 точки." << endl;
        return 1;
    }

    vector<double> x(n), y(n);
    cout << "Введите x y построчно:" << endl;
    for (int i = 0; i < n; ++i) {
        cin >> x[i] >> y[i];
    }

    // Проверка равномерности шага
    double h0 = (x[n-1] - x[0]) / (n - 1);
    const double eps = 1e-9;
    bool ok = true;
    for (int i = 1; i < n; ++i) {
        if (fabs((x[i] - x[i-1]) - h0) > eps) {
            ok = false;
            break;
        }
    }
    if (!ok) {
        cerr << "Предупреждение: узлы не равноотстоящие." << endl;
    }

    // ---- Таблица разностей ------------------------------------
    vector<vector<double>> tab = build_table(y);

    // ---- Параметры интерполяции -------------------------------
    double a, b;
    int m;
    cout << "Введите отрезок [a b]: ";
    cin >> a >> b;
    cout << "Введите число точек для графика: ";
    cin >> m;

    if (m < 2) {
        cerr << "Ошибка: нужно минимум 2 точки." << endl;
        return 1;
    }

    // ---- Запись в CSV -----------------------------------------
    ofstream fout("out.csv");
    if (!fout) {
        cerr << "Ошибка: не создать файл." << endl;
        return 1;
    }

    fout << "x,y\n";
    double step = (b - a) / (m - 1);
    for (int i = 0; i < m; ++i) {
        double cx = a + i * step;
        double cy = newton_back(cx, x, y, tab);
        fout << fixed << setprecision(8) << cx << "," << cy << "\n";
    }

    fout.close();

    cout << "\nГотово! Результат в файле 'out.csv'" << endl;
    cout << "Исходные точки:" << endl;
    for (int i = 0; i < n; ++i) {
        cout << "x=" << x[i] << " y=" << y[i] << endl;
    }

    return 0;
}
