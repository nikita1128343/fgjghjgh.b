#include <iostream>  // Для ввода/вывода (cin, cout, cerr)
#include <fstream>   // Для работы с файлами (ofstream)
#include <vector>    // Для использования динамических массивов (vector)
#include <iomanip>   // Для форматированного вывода (setprecision, fixed)
#include <cmath>     // Для математических функций (fabs)

using namespace std; // Чтобы не писать std:: перед каждым вызовом

// Функция построения таблицы обратных (конечных) разностей
// Теория: для интерполяции назад используются разности:
// ∇y_n = y_n - y_{n-1}, ∇²y_n = ∇y_n - ∇y_{n-1} и т.д.
vector<vector<double>> build_table(const vector<double>& y) {
    int n = y.size();                    // Количество узлов
    vector<vector<double>> tab(n, vector<double>(n, 0.0));  // Таблица n×n, заполнена нулями

    // Нулевой порядок — сами значения функции в узлах
    // Теория: ∇⁰y_i = y_i
    for (int i = 0; i < n; ++i) {
        tab[0][i] = y[i];                // Первая строка таблицы — исходные y
    }

    // Вычисление разностей высших порядков (1, 2, ..., n-1)
    // Теория: ∇ᵏy_i = ∇ᵏ⁻¹y_i - ∇ᵏ⁻¹y_{i-1}
    for (int k = 1; k < n; ++k) {        // k — порядок разности
        for (int i = k; i < n; ++i) {    // i — индекс узла (начинаем с k, т.к. нужно k предыдущих)
            tab[k][i] = tab[k-1][i] - tab[k-1][i-1];  // Рекуррентная формула
        }
    }
    return tab;  // Возвращаем заполненную таблицу разностей
}

// Функция интерполяции по формуле Ньютона для интерполяции назад
// Теория: P_n(x) = y_n + t·∇y_n + t(t+1)/2!·∇²y_n + ... + t(t+1)...(t+n-1)/n!·∇ⁿy_n
// где t = (x - x_n)/h, h — шаг между узлами
double newton_back(double x, const vector<double>& xx, const vector<double>& yy,
                   const vector<vector<double>>& tab) {
    int n = xx.size();                   // Количество узлов
    
    double h = xx[1] - xx[0];            // Шаг сетки (предполагается равномерным)
    // Теория: нормированная переменная t. При x = x_n → t = 0
    double t = (x - xx[n-1]) / h;        // Сдвиг относительно последнего узла
    
    double res = tab[0][n-1];            // Начальное значение: y_n (слагаемое нулевого порядка)
    double pr = 1.0;                     // Множитель для накопления произведения t(t+1)...(t+k-1)
    
    // Цикл по порядкам разностей (k = 1, 2, ..., n-1)
    // Теория: добавляем слагаемые ∇ᵏy_n · [t(t+1)...(t+k-1)]/k!
    for (int k = 1; k < n; ++k) {
        pr *= (t + k - 1) / k;           // Вычисляем очередной коэффициент (обобщённый бином)
                                         // На первом шаге (k=1): pr = (t+0)/1 = t
                                         // На втором (k=2): pr = t·(t+1)/2 и т.д.
        res += tab[k][n-1] * pr;         // Добавляем слагаемое ∇ᵏy_n · pr
    }
    return res;                          // Возвращаем интерполированное значение
}

int main() {
    setlocale(LC_ALL, "Russian");        // Русские символы в консоли

    // ---- Ввод исходных данных ------------------------------------------
    int n;                               // Количество опорных точек
    cout << "Введите число точек: ";
    cin >> n;

    if (n < 2) {                         // Проверка: для интерполяции нужно хотя бы 2 точки
        cerr << "Ошибка: нужно минимум 2 точки." << endl;
        return 1;                        // Аварийное завершение
    }

    vector<double> x(n), y(n);           // Массивы для координат узлов
    cout << "Введите x y построчно:" << endl;
    for (int i = 0; i < n; ++i) {
        cin >> x[i] >> y[i];             // Считываем пары (x, y)
    }

    // Проверка равноотстоящих узлов (требование формулы Ньютона назад)
    // Теория: формула Ньютона назад работает только для равномерной сетки
    double h0 = (x[n-1] - x[0]) / (n - 1);  // Вычисляем теоретический шаг
    const double eps = 1e-9;                // Допуск для сравнения чисел с плавающей точкой
    bool ok = true;                         // Флаг равномерности
    for (int i = 1; i < n; ++i) {
        if (fabs((x[i] - x[i-1]) - h0) > eps) {  // Если отклонение больше допуска
            ok = false;                          // Сетка неравномерная
            break;
        }
    }
    if (!ok) {
        cerr << "Предупреждение: узлы не равноотстоящие." << endl;  // Предупреждение, но работаем дальше
    }

    // ---- Построение таблицы обратных разностей -------------------------
    // Теория: вычисляем ∇ᵏy_i для всех k и i
    vector<vector<double>> tab = build_table(y);

    // ---- Параметры интерполяции (для построения графика) --------------
    double a, b;                           // Левая и правая границы отрезка
    int m;                                 // Количество точек для графика
    cout << "Введите отрезок [a b]: ";
    cin >> a >> b;
    cout << "Введите число точек для графика: ";
    cin >> m;

    if (m < 2) {
        cerr << "Ошибка: нужно минимум 2 точки." << endl;
        return 1;
    }

    // ---- Запись результатов в CSV-файл ---------------------------------
    // Теория: сохраняем пары (x, P_n(x)) для последующей визуализации
    ofstream fout("out.csv");              // Открываем файл для записи
    if (!fout) {                           // Проверка: удалось ли создать файл
        cerr << "Ошибка: не создать файл." << endl;
        return 1;
    }

    fout << "x,y\n";                       // Заголовок CSV (два столбца: x и y)
    
    double step = (b - a) / (m - 1);       // Шаг между генерируемыми точками
    for (int i = 0; i < m; ++i) {
        double cx = a + i * step;          // Очередное значение x
        double cy = newton_back(cx, x, y, tab);  // Вычисляем P_n(x) по Ньютону назад
        fout << fixed << setprecision(8) << cx << "," << cy << "\n";  // Запись в файл
    }

    fout.close();                          // Закрываем файл
    
    // ---- Вывод справки в консоль ---------------------------------------
    cout << "\nГотово! Результат в файле 'out.csv'" << endl;
    cout << "Исходные точки:" << endl;
    for (int i = 0; i < n; ++i) {
        cout << "x=" << x[i] << " y=" << y[i] << endl;
    }

    return 0;                              // Успешное завершение
}
