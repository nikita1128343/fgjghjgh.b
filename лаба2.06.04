#include <iostream>
#include <fstream>
#include <vector>
#include <iomanip>
#include <cmath>

using namespace std;

// Функция построения таблицы обратных разностей
// Возвращает двумерный вектор, где diff[k][i] — разность k-го порядка в точке i
vector<vector<double>> compute_backward_differences(const vector<double>& y) {
int n = y.size();
vector<vector<double>> diff(n, vector<double>(n, 0.0));

// Нулевой порядок — сами значения функции
for (int i = 0; i < n; ++i) {
diff[0][i] = y[i];
}

// Вычисление разностей высших порядков
for (int k = 1; k < n; ++k) {
for (int i = k; i < n; ++i) {
diff[k][i] = diff[k-1][i] - diff[k-1][i-1];
}
}
return diff;
}

// Интерполяция по формуле Ньютона назад в точке x
// x_vals — массив узлов (равноотстоящие)
// y_vals — массив значений
// diff — предвычисленная таблица обратных разностей
double newton_backward(double x, const vector<double>& x_vals, const vector<double>& y_vals,
const vector<vector<double>>& diff) {
int n = x_vals.size();
double h = x_vals[1] - x_vals[0]; // шаг (предполагается постоянным)
double t = (x - x_vals[n-1]) / h; // нормированная переменная

double result = diff[0][n-1]; // y_n
double term = 1.0;

for (int k = 1; k < n; ++k) {
term *= (t + k - 1) / k; // t*(t+1)*...*(t+k-1)/k!
result += diff[k][n-1] * term; // добавляем ∇^k y_n * term
}
return result;
}

int main() {
setlocale(LC_ALL, "Russian"); // для вывода сообщений на русском

// ---- Ввод исходных данных ------------------------------------------
int n;
cout << "Введите количество точек: ";
cin >> n;

if (n < 2) {
cerr << "Ошибка: необходимо хотя бы две точки для интерполяции." << endl;
return 1;
}

vector<double> x_vals(n), y_vals(n);
cout << "Введите точки (x y) по одной на строке:" << endl;
for (int i = 0; i < n; ++i) {
cin >> x_vals[i] >> y_vals[i];
}

// Проверка равноотстоящих узлов (с допуском)
double h = (x_vals[n-1] - x_vals[0]) / (n - 1);
const double eps = 1e-9;
bool equally_spaced = true;
for (int i = 1; i < n; ++i) {
if (fabs((x_vals[i] - x_vals[i-1]) - h) > eps) {
equally_spaced = false;
break;
}
}
if (!equally_spaced) {
cerr << "Предупреждение: узлы не равноотстоящие. Формула Ньютона назад предполагает равномерный шаг." << endl;
// Продолжаем со средним шагом; результат может быть неточным.
}

// ---- Построение таблицы обратных разностей -------------------------
vector<vector<double>> diff = compute_backward_differences(y_vals);

// ---- Параметры интерполяции ----------------------------------------
double xmin, xmax;
int num_points;
cout << "Введите отрезок интерполяции [xmin xmax]: ";
cin >> xmin >> xmax;
cout << "Введите количество точек для построения графика: ";
cin >> num_points;

if (num_points < 2) {
cerr << "Ошибка: количество точек должно быть не менее 2." << endl;
return 1;
}

// ---- Генерация интерполированных значений и запись в CSV ----------
ofstream outfile("interpolation.csv");
if (!outfile) {
cerr << "Ошибка: не удалось создать выходной файл." << endl;
return 1;
}

// Заголовок CSV
outfile << "x,y_interpolated\n";

double step = (xmax - xmin) / (num_points - 1);
for (int i = 0; i < num_points; ++i) {
double x = xmin + i * step;
double y = newton_backward(x, x_vals, y_vals, diff);
outfile << fixed << setprecision(8) << x << "," << y << "\n";
}

outfile.close();

cout << "\nИнтерполяция завершена. Результат сохранён в файл 'interpolation.csv'." << endl;
cout << "Откройте этот файл в Excel и постройте точечную диаграмму (Scatter)." << endl;

// Для справки выведем исходные точки
cout << "\nИсходные точки:" << endl;
for (int i = 0; i < n; ++i) {
cout << "x = " << x_vals[i] << ", y = " << y_vals[i] << endl;
}

return 0;
}
