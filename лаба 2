#include <iostream>
#include <vector>
#include <iomanip>
#include <cmath>

using namespace std;

int main() {
    setlocale(LC_ALL, "rus");
    int n;
    cout << "Введите размер матрицы: ";
    cin >> n;

    // Ввод матрицы
    vector<vector<double>> a(n, vector<double>(n));
    cout << "Введите матрицу:\n";
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> a[i][j];

    // Создаем копию для LU-разложения
    vector<vector<double>> lu = a;//копирую исходную матрицу в lu(она будет заменена на объединенную матр L и U)
    vector<int> p(n);
    for (int i = 0; i < n; i++) p[i] = i;//массив p хранит информацию о перестановках строк(для выбора главного эл-та) изнач. строки не переставлены

    // LU-разложение с выбором главного элемента
    for (int k = 0; k < n; k++) {//цикл по к - номер текущ столбца(и строки) для обработки
        // поиск главного элемента(ищем строку с макс эл-ом в столбце k начиная с текущ строки к)
        int max_row = k;
        double max_val = abs(lu[k][k]);
        for (int i = k + 1; i < n; i++) {
            if (abs(lu[i][k]) > max_val) {
                max_val = abs(lu[i][k]);
                max_row = i;
            }
        }

        if (max_val < 1e-12) {
            cout << "Матрица вырождена\n";
            return 1;
        }//выбор главного эл-та уменьшает накопление ошибок округления.(глав эл-т не должен быть нулем, иначе матрица вырожд)

        // Меняем строки
        if (max_row != k) {
            swap(lu[k], lu[max_row]);
            swap(p[k], p[max_row]);
        }//меняем местами строки k и max_row в матрицу и массиве перестановок

        // Разложение
        for (int i = k + 1; i < n; i++) {
            lu[i][k] = lu[i][k] / lu[k][k];//вычисл множители и сохр в lu[i][k]
            for (int j = k + 1; j < n; j++) {
                lu[i][j] = lu[i][j] - lu[i][k] * lu[k][j];//обнов остаток подматрицы 
            }
        }
    }//в результате в lu хранятся нижняя треуг матрица L(с единичной диагональю)-под диаг, верхняя треуг матр U - на диагонали и выше, P*A = L*U

    // Обратная матрица
    vector<vector<double>> inv(n, vector<double>(n, 0));

    // Для каждого столбца единичной матрицы
    for (int col = 0; col < n; col++) {
        // Правая часть Pb
        vector<double> b(n);
        for (int i = 0; i < n; i++) {
            if (p[i] == col) b[i] = 1;
            else b[i] = 0;
        }//взяли единичный вектор b  и применили к нему перестановки строк P(нужно решить A*x = b => с учетом перестановок P*A*x = P*b и P*A = L*U => L*U*x = P*b

        // Решаем Ly = b
        //L - это нижняя треугольная матрица(все элементы выше главной диагонали = 0)
            // Главная диагональ у L = 1 (единицы)
            // 
            // Как это выглядит на примере матрицы 3x3:
            // 
            // [ 1   0   0 ]   [ y1 ]   [ b1 ]
            // [ L21 1   0 ] * [ y2 ] = [ b2 ]
            // [ L31 L32 1 ]   [ y3 ]   [ b3 ]
            // 
            // Распишем умножение:
            // y1 = b1
            // L21*y1 + y2 = b2
            // L31*y1 + L32*y2 + y3 = b3
            // 
            // Из каждого уравнения выражаем y:
            // y1 = b1
            // y2 = b2 - L21*y1
            // y3 = b3 - L31*y1 - L32*y2
            // 
            // То есть: y[i] = b[i] - (сумма L[i][j] * y[j] для всех j от 0 до i-1)
        vector<double> y(n);
        for (int i = 0; i < n; i++) {
            double sum = 0;
            // Складываем все L[i][j] * y[j] для уже найденных y
            for (int j = 0; j < i; j++) {
                sum += lu[i][j] * y[j]; // lu[i][j] - это элементы L
            }
            // Вычисляем y[i] вычитанием суммы из b[i]
            y[i] = b[i] - sum;
        }

        // Решаем Ux = y
        // U - это верхняя треугольная матрица (все элементы ниже главной диагонали = 0)
// 
// Как это выглядит на примере матрицы 3x3:
// 
// [ U11 U12 U13 ]   [ x1 ]   [ y1 ]
// [ 0   U22 U23 ] * [ x2 ] = [ y2 ]
// [ 0   0   U33 ]   [ x3 ]   [ y3 ]
// 
// Распишем умножение (снизу вверх):
// U33*x3 = y3  →  x3 = y3 / U33
// U22*x2 + U23*x3 = y2  →  x2 = (y2 - U23*x3) / U22
// U11*x1 + U12*x2 + U13*x3 = y1  →  x1 = (y1 - U12*x2 - U13*x3) / U11
// 
// То есть: x[i] = (y[i] - (сумма U[i][j] * x[j] для всех j от i+1 до n-1)) / U[i][i]
        vector<double> x(n);
        // Идём снизу вверх (с последней строки к первой)
        for (int i = n - 1; i >= 0; i--) {
            double sum = 0;
            // Складываем все U[i][j] * x[j] для уже найденных x (которые справа)
            for (int j = i + 1; j < n; j++) {
                sum += lu[i][j] * x[j];// lu[i][j] - это элементы U
            }
            // Вычисляем x[i] = (y[i] - сумма) / диагональный элемент U[i][i]
            x[i] = (y[i] - sum) / lu[i][i];
        }

        // Записываем в обратную матрицу
        for (int i = 0; i < n; i++) {
            inv[i][col] = x[i];//x - столбец обратной матрицы(обратная матрица это матрица столбцы которой явл решениями систем Ax = b)
        }
    }

    // Вывод обратной матрицы
    cout << "\nОбратная матрица:\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << fixed << setprecision(6) << setw(12) << inv[i][j];
        }
        cout << endl;
    }

    // Проверка A * A^-1 = I(умн исходную a на inv(обратную) должна получиться единичная)
    cout << "\nПроверка (A * A^-1):\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            double sum = 0;
            for (int k = 0; k < n; k++) {
                sum += a[i][k] * inv[k][j];
            }
            if (abs(sum) < 1e-10) sum = 0;
            cout << fixed << setprecision(6) << setw(12) << sum;
        }
        cout << endl;
    }

    return 0;
}
