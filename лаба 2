#include <iostream>
#include <vector>
#include <iomanip>
#include <cmath>

using namespace std;

//ф-ия выч факториала числа n(n! = 1*2*3*...*n)
//для деления на k! в формуле Ньютона
int fact(int n) {
    int f = 1; //с 1
    for (int i = 2; i <= n; i++) f *= i; //умн на 2*3*4...*n
    return f;
}

int main() {
    setlocale(LC_ALL, "RUS");
    int n;
    cout << "Количество точек: ";
    cin >> n;

    vector<double> x(n), y(n); //массивы для x и y

    cout << "Введите x и y:\n";
    for (int i = 0; i < n; i++) {
        cin >> x[i] >> y[i];
    }

    // Проверка равномерности шага(формула Ньютона работает только при равномерном шаге)
    double h = x[1] - x[0];//выч шаг как разность между первыми двумя x
    for (int i = 1; i < n; i++) {//пров все соседние точки
        if (abs(x[i] - x[i - 1] - h) > 1e-10) {//если разница между любыми соседними x отлич от h больше чем на 10^-10
            cout << "Ошибка: неравномерный шаг!\n";
            return 1;
        }
    }

    
   

    double X;                        // точка в которой хотим узнать значение функции
    cout << "x для интерполяции: ";
    cin >> X;                        

    
    // таблица обратных конечных разностей
    // d[i][j] - где i номер точки, j порядок разности
    // j=0: y (значения функции)
    // j=1: ∇y (разности 1-го порядка)
    // j=2: ∇²y (разности 2-го порядка)
    // j=3: ∇³y (разности 3-го порядка) и т.д.

    vector<vector<double>> d(n, vector<double>(n, 0));  // Создаем квадратную таблицу n×n, заполняем нулями
    for (int i = 0; i < n; i++) d[i][0] = y[i];         // В столбец 0 записываем значения y

    
    // Формула: ∇ᵏyᵢ = ∇ᵏ⁻¹yᵢ - ∇ᵏ⁻¹yᵢ₋₁
    // Считаем "снизу вверх" (от последней точки к первой)

    for (int j = 1; j < n; j++) {           // j - порядок разности (1, 2, 3...)
        for (int i = n - 1; i >= j; i--) {    // i - номер точки (идет от последней к j)
            // Обратная разность = разность между разностью предыдущего порядка
            // в текущей точке и в точке выше
            d[i][j] = d[i][j - 1] - d[i - 1][j - 1];
        }
    }
   


    cout << "\nТаблица обратных разностей:\n";
    for (int i = 0; i < n; i++) {           // для каждой точки
        cout << x[i] << "\t";                // выводим x
        for (int j = 0; j <= i; j++) {       // выводим все разности до порядка i
            cout << d[i][j] << "\t";         // выводим значение разности
        }
        cout << endl;                        
    }
    
    // P(x) = yₙ + t·∇yₙ + t(t+1)/2!·∇²yₙ + t(t+1)(t+2)/3!·∇³yₙ + ...
    // где t = (x - xₙ)/h, а xₙ - последний узел

    double t = (X - x[n - 1]) / h;    // Вычисляем t = (X - последний_x) / шаг

    double result = d[n - 1][0];      // Начинаем с yₙ (последнее значение из таблицы)
    double prod = 1.0;              // Будет хранить произведение t·(t+1)·(t+2)·...


    cout << "\nФормула: P(x) = y_n + t*dy_n + t(t+1)/2!*d2y_n + t(t+1)(t+2)/3!*d3y_n + ...\n";
    cout << "t = " << t << "\n\n";
    cout << "P(" << X << ") = " << d[n - 1][0];  // Начинаем вывод с yₙ

    // Здесь применяем формулу Ньютона: добавляем члены с k=1,2,3...

    for (int k = 1; k < n; k++) {               // k - порядок члена (1,2,3...)
        prod *= (t + k - 1);                    // Вычисляем t·(t+1)·(t+2)·...·(t+k-1)
        // Для k=1: prod = t
        // Для k=2: prod = t·(t+1)
        // Для k=3: prod = t·(t+1)·(t+2)

        double term = prod * d[n - 1][k] / fact(k);  // Вычисляем член формулы:
        // term = [t·(t+1)·...·(t+k-1)] / k! * ∇ᵏyₙ
        // Это и есть k-й член в формуле Ньютона

        result += term;                          // Добавляем член к результату


        double display_term = term;               // Копируем член для вывода
        if (abs(display_term) < 1e-10) display_term = 0;  // Если очень маленький - обнуляем

        // Выводим добавленный член в понятном виде

        if (display_term >= 0) {
            // Если член положительный, ставим знак +
            cout << " + [" << prod << "/" << k << "!]*" << d[n - 1][k] << " = " << display_term;
        }
        else {
            // Если член отрицательный, ставим знак - и берем модуль prod
            cout << " - [" << -prod << "/" << k << "!]*" << d[n - 1][k] << " = " << display_term;
        }
    }

    // Выводим полученное значение функции в точке X

    if (abs(result) < 1e-10) result = 0;          // Обнуляем погрешности в конечном результате

    cout << "\n\nРЕЗУЛЬТАТ: " << fixed << setprecision(6) << result << endl;
    

    return 0;  
}
